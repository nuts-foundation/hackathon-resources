{
  "medicatieoverdracht-gf": {
    "organization": {
      "format": {
        "ldp_vc": {
          "proof_type": [
            "JsonWebSignature2020",
            "DeziIDJWT07"
          ]
        },
        "jwt_vc": {
          "alg": [
            "PS256",
            "RS256",
            "ES256"
          ]
        },
        "jwt_vp": {
          "alg": [
            "ES256",
            "PS256",
            "RS256"
          ]
        }
      },
      "id": "pd_any_care_organization",
      "name": "Care organization",
      "purpose": "Finding a care organization and practitioner",
      "submission_requirements": [
        {
          "name": "Required credentials",
          "rule": "all",
          "from": "required"
        },
        {
          "name": "User identity",
          "rule": "pick",
          "min": 0,
          "max": 10,
          "from": "user-identity"
        }
      ],
      "input_descriptors": [
        {
          "id": "id_uzicert_orgcredential",
          "name": "Care organization identity from UZI-server certificate",
          "purpose": "Finding a care organization for authorizing access to medical metadata.",
          "group": ["required"],
          "constraints": {
            "fields": [
              {
                "path": [
                  "$.type"
                ],
                "filter": {
                  "type": "string",
                  "const": "HealthcareOrganizationCredential"
                }
              },
              {
                "id": "organization_id",
                "path": [
                  "$.credentialSubject[0].id",
                  "$.credentialSubject.id"
                ],
                "filter": {
                  "type": "string",
                  "pattern": "^did:web:"
                }
              },
              {
                "id": "organization_name",
                "path": [
                  "$.credentialSubject[0].organization.name",
                  "$.credentialSubject.organization.name"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "organization_ura",
                "path": [
                  "$.credentialSubject[0].organization.ura",
                  "$.credentialSubject.organization.ura"
                ]
              }
            ]
          }
        },
        {
          "id": "id_patient_enrollment",
          "name": "The patient enrollment credential",
          "group": ["required"],
          "constraints": {
            "fields": [
              {
                "path": [
                  "$.type"
                ],
                "filter": {
                  "type": "string",
                  "const": "PatientEnrollmentCredential"
                }
              },
              {
                "path": [
                  "$.credentialSubject[0].id",
                  "$.credentialSubject.id"
                ],
                "filter": {
                  "type": "string",
                  "pattern": "^did:web:"
                }
              },
              {
                "id": "patient_enrollment_identifier",
                "path": [
                  "$.credentialSubject[0].patientId",
                  "$.credentialSubject.patientId"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "patient_enrollment_registered_by",
                "path": [
                  "$.credentialSubject[0].registeredBy",
                  "$.credentialSubject.registeredBy"
                ],
                "filter": {
                  "type": "string"
                }
              }
            ]
          }
        },
        {
          "id": "id_healthcare_professional_delegation",
          "name": "The healthcare professional delegation credential",
          "group": ["required"],
          "constraints": {
            "fields": [
              {
                "path": [
                  "$.type"
                ],
                "filter": {
                  "type": "string",
                  "const": "HealthCareProfessionalDelegationCredential"
                }
              },
              {
                "path": [
                  "$.credentialSubject[0].id",
                  "$.credentialSubject.id"
                ],
                "filter": {
                  "type": "string",
                  "pattern": "^did:web:"
                }
              },
              {
                "id": "delegation_registered_by",
                "path": [
                  "$.credentialSubject[0].registeredBy",
                  "$.credentialSubject.registeredBy"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "delegation_role_code",
                "path": [
                  "$.credentialSubject[0].roleCode",
                  "$.credentialSubject.roleCode"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "delegation_authorization_rule",
                "path": [
                  "$.credentialSubject[0].authorizationRule",
                  "$.credentialSubject.authorizationRule"
                ],
                "filter": {
                  "type": "string"
                }
              }
            ]
          }
        },
        {
          "id": "id_dezicredential",
          "group": ["user-identity"],
          "constraints": {
            "fields": [
              {
                "path": [
                  "$.type"
                ],
                "filter": {
                  "type": "string",
                  "const": "DeziUserCredential"
                }
              },
              {
                "id": "organization_ura_dezi",
                "path": [
                  "$.credentialSubject.identifier"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "user_id",
                "path": [
                  "$.credentialSubject.employee.identifier"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "user_initials",
                "path": [
                  "$.credentialSubject.employee.initials"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "user_surname",
                "path": [
                  "$.credentialSubject.employee.surname"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "user_surname_prefix",
                "path": [
                  "$.credentialSubject.employee.surnamePrefix"
                ],
                "filter": {
                  "type": "string"
                }
              },
              {
                "id": "user_role",
                "path": [
                  "$.credentialSubject.employee.role"
                ],
                "filter": {
                  "type": "string"
                }
              }
            ]
          }
        }
      ]
    }
  }
}